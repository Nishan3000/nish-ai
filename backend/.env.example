# NISH backend — copy this file to .env and adjust as needed.
# Never commit .env (it is in .gitignore).

# development | production
ENVIRONMENT=development

# Comma-separated browser origins allowed to call this API
CORS_ORIGINS=http://localhost:3000

# Database — matches the docker-compose Postgres service.
# Change the password for anything beyond local development.
DATABASE_URL=postgresql+psycopg://nish:nish@localhost:5432/nish

# Ollama server
OLLAMA_BASE_URL=http://localhost:11434
# Any chat model you have pulled, e.g. qwen3:8b, llama3.2, mistral
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=120

# Input limits
MAX_MESSAGE_CHARS=8000
MAX_HISTORY_MESSAGES=40

# --- Agent (autonomous coding) ---
# The ONLY directory tree the agent may read. Point at the project you
# want NISH to work on. Never point this at your home directory.
AGENT_WORKSPACE_ROOT=./workspace
AGENT_AUDIT_LOG_PATH=./audit/agent-audit.jsonl
AGENT_MAX_READ_BYTES=256000
AGENT_MAX_TREE_ENTRIES=2000
AGENT_PLANNER_MAX_ATTEMPTS=3
